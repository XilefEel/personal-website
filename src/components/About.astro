---
import { MapPin, GraduationCap } from "@lucide/astro";
import aboutImage from "../assets/about_image.jpg";
import { Image } from "astro:assets";
---

<section id="about" class="bg-white px-8 pt-16 md:px-12 md:pt-20">
  <div class="mx-auto max-w-5xl">
    <h2
      class="fade-in mb-8 flex justify-center text-3xl font-extrabold text-purple-600 md:text-4xl"
    >
      About Me
    </h2>

    <div class="grid items-center gap-12 md:grid-cols-6">
      <div class="md:col-span-2">
        <Image
          src={aboutImage}
          alt="Felix Lee"
          class="w-full rounded-lg object-cover shadow-lg"
          loading="lazy"
        />
      </div>

      <div class="fade-in flex flex-col gap-6 md:col-span-4">
        <div>
          <p class="text-2xl font-semibold text-gray-900">Felix Lee</p>
          <p class="text-sm text-gray-500">CS student at BINUS University</p>
        </div>

        <div class="flex flex-wrap gap-4">
          <span class="flex items-center gap-1 text-sm text-gray-500">
            <MapPin class="size-4 shrink-0" />
            Tangerang, Indonesia
          </span>

          <span class="flex items-center gap-1 text-sm text-gray-500">
            <GraduationCap class="size-4 shrink-0" />
            BINUS University
          </span>
        </div>

        <p class="fade-in text-base leading-relaxed text-gray-800">
          I love building full-stack apps that are clean, functional, and
          actually enjoyable to use. Currently working with
          <span class="font-medium text-purple-600">React</span>,
          <span class="font-medium text-purple-600">TypeScript</span>,
          <span class="font-medium text-purple-600">Tailwind CSS</span>, and
          <span class="font-medium text-purple-600">Rust</span>.
        </p>

        <p class="fade-in text-base leading-relaxed text-gray-800">
          Started coding because I wanted to build my own games, but now I'm
          hooked on creating all kinds of apps and tools that solve the problems
          I care about.
        </p>

        <div
          class="fade-in flex items-center gap-2 rounded-lg border border-gray-100 bg-gray-50 px-4 py-2.5"
        >
          <div class="size-2 rounded-full bg-green-400"></div>
          <span class="text-sm text-gray-500">Currently building</span>
          <span class="text-sm font-medium text-gray-900">MindNest</span>
          <span class="text-sm text-gray-500"
            >- a desktop app for my thoughts and tasks</span
          >
        </div>

        <div class="fade-in flex flex-wrap gap-x-4 gap-y-2 pt-1">
          <span class="text-sm text-gray-500">🧩 Rubik's cube under 30s</span>
          <span class="text-sm text-gray-400">·</span>
          <span class="text-sm text-gray-500">🗺️ Learning Chinese</span>
          <span class="text-sm text-gray-400">·</span>
          <span class="text-sm text-gray-500">💪 Clean chin ups</span>
        </div>
      </div>
    </div>

    <div class="fade-in mx-auto mt-8 max-w-4xl overflow-x-auto">
      <img
        src="https://ghchart.rshah.org/7c3aed/XilefEel"
        alt="Felix Lee's GitHub contribution graph"
        class="w-full min-w-[600px]"
      />
    </div>
  </div>
</section>
