---
import { Icon } from "astro-icon/components";

const size = Astro.props.size || 24;
---

<div class="flex flex-row justify-center gap-8">
  <a
    href="https://github.com/XilefEel"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Visit my GitHub profile"
    class="text-purple-600 transition-all hover:scale-110 hover:text-purple-800"
  >
    <Icon name="lucide:github" size={size} />
  </a>
  <a
    href="https://www.instagram.com/felixlee274/"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Visit my Instagram profile"
    class="text-purple-600 transition-all hover:scale-110 hover:text-pink-500"
  >
    <Icon name="lucide:instagram" size={size} />
  </a>
  <a
    href="https://www.linkedin.com/in/felix-lee-115515277/"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Visit my LinkedIn profile"
    class="text-purple-600 transition-all hover:scale-110 hover:text-blue-600"
  >
    <Icon name="lucide:linkedin" size={size} />
  </a>
</div>
