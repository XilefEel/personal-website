---
const links = [
  { name: "About", href: "#about" },
  { name: "Tech Stack", href: "#tech" },
  { name: "Education", href: "#education" },
  { name: "Achievements", href: "#achievements" },
  { name: "Projects", href: "#projects" },
];
---

<nav class="fixed top-0 z-50 w-full bg-white/90 shadow-sm backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-6 py-4 md:px-8">
    <div class="flex items-center justify-center md:justify-between">
      <a href="#home" class="hidden text-lg font-bold text-purple-600 md:block">
        Felix Lee
      </a>

      <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-gray-700 transition-colors hover:text-purple-600 md:text-base"
            >
              {link.name}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</nav>
