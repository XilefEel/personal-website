---
import { Image } from "astro:assets";
const { tech } = Astro.props;
---

<div
  class="inline-flex items-center gap-2 rounded-full border border-white/35 bg-white/30 px-4 py-2 transition select-none hover:scale-105 hover:bg-white/40"
>
  <Image
    src={tech.icon}
    alt={`${tech.name} logo`}
    class="h-5 w-5 object-contain"
    loading="lazy"
  />
  <span class="text-sm font-medium text-white">
    {tech.name}
  </span>
</div>
