---
const { category } = Astro.props;
import { Image } from "astro:assets";
---

<div>
  <h3 class="text-xl md:text-2xl font-semibold text-purple-600 mb-6">
    {category.category}
  </h3>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      category.skills.map((skill: { icon: any; name: string }) => (
        <div class="group bg-white rounded-2xl flex flex-col items-center border border-gray-100 p-6 shadow-md hover:shadow-lg hover:scale-[1.02] transition-all duration-300">
          <div class="flex items-center justify-center h-16 w-full mb-4">
            <Image
              src={skill.icon}
              alt={`${skill.name} logo`}
              class="h-full w-full object-contain"
              loading="lazy"
            />
          </div>

          <h3 class="text-gray-700 font-semibold text-sm group-hover:text-purple-600 transition-colors">
            {skill.name}
          </h3>
        </div>
      ))
    }
  </div>
</div>
