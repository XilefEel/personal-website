---
import { ExternalLink, Github } from "@lucide/astro";
import ProjectCard from "./ProjectCard.astro";
const projects = [
  {
    title: "MindNest",
    description:
      "An all-in-one desktop productivity app to organize thoughts and tasks seamlessly.",
    gradient: "from-blue-500 to-purple-600",
    link: "https://github.com/XilefEel/MindNest",
    tech: ["React", "TypeScript", "Rust", "Tauri"],
    status: "In Progress",
  },
  {
    title: "Nemos",
    description:
      "A mobile app to help solve the injustice happening in Indonesia",
    gradient: "from-green-500 to-teal-600",
    link: "https://github.com/G3310-dev/Nemos",
    tech: ["Flutter", "Dart", "Firebase"],
    status: "Completed",
  },
  {
    title: "Commitly",
    description:
      "A desktop app that visualizes your GitHub repos and commits in a beautiful way.",
    gradient: "from-orange-500 to-red-600",
    link: "https://github.com/XilefEel/Commitly",
    tech: ["React", "TypeScript", "Rust", "Tauri"],
    status: "In Progress",
  },
];
---

<section id="projects" class="bg-purple-50 px-8 py-16 md:px-12 md:py-20">
  <div class="mx-auto max-w-6xl">
    <h3 class="fade-in mb-12 text-center text-3xl font-bold md:text-4xl">
      Featured Projects
    </h3>
    <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="fade-in flex justify-center text-center">
      <a
        href="https://github.com/XilefEel"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-xl bg-purple-600 px-6 py-3 font-semibold text-white shadow-md transition-colors duration-200 hover:bg-purple-700 hover:shadow-lg"
      >
        <Github class="size-5" />
        <span>View All Projects on GitHub</span>
        <ExternalLink class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
