---
import { Image } from "astro:assets";
const { achievement } = Astro.props;
---

<div
  class="fade-in overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition hover:scale-[1.02] hover:border-purple-500 hover:shadow-md"
>
  <div class="flex w-full items-center justify-center bg-gray-50 p-3">
    <Image
      src={achievement.src}
      alt={achievement.title}
      class="max-h-72 w-auto rounded-md object-contain"
      loading="lazy"
    />
  </div>
  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-xl font-semibold text-purple-600">
      {achievement.title}
    </h3>
    <p class="mt-2 text-sm text-gray-600">
      {achievement.description}
    </p>
  </div>
</div>
